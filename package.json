{
  "name": "self-evolving-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsc --noEmit && vite build",
    "check": "npm run lint && npm run build",
    "smoke": "node scripts/smoke-test.mjs",
    "android:install-tools": "bash scripts/install-android-toolchain.sh",
    "android:build": "bash scripts/build-android.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "better-sqlite3": "^11.10.0",
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "eslint": "^9.26.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
